<Window x:Class="krasotkaDBLevonTEST.EveryDay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Режим администратора" Height="794" Width="1000"
        Background="#FF0D5C0D" Foreground="White"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF1E8449" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="👩‍💼 РЕЖИМ АДМИНИСТРАТОРА" 
                         FontSize="24" FontWeight="Bold" 
                         Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка - Мастера и Клиенты -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Мастер:" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="16" Margin="0,0,0,10"/>

                <ListBox x:Name="mastersListBox" 
                        Background="White" Foreground="Black"
                        Height="200" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="MasterName"
                        SelectionChanged="MastersListBox_SelectionChanged"/>

                <TextBlock Text="Тел.клиента:" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="16" Margin="0,20,0,10"/>

                <TextBox x:Name="clientPhoneTextBox" 
                        FontSize="14" Padding="8" Margin="0,0,0,10"
                        Background="White" Foreground="Black" 
                        BorderThickness="1" BorderBrush="#FF27AE60"
                        ToolTip="Введите телефон клиента"/>

                <Button x:Name="findClientButton" Content="🔍 НАЙТИ КЛИЕНТА"
                        Click="FindClientButton_Click"
                        Background="#FF3498DB" Foreground="White"
                        Margin="0,0,0,20" Padding="10,8"
                        FontSize="12" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="anonymousClientButton" Content="👤 АНОНИМНЫЙ КЛИЕНТ"
                        Click="AnonymousClientButton_Click"
                        Background="#FF9B59B6" Foreground="White"
                        Padding="10,8"
                        FontSize="12" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>

                <TextBlock x:Name="clientInfoTextBlock" 
                         Foreground="White" FontSize="14"
                         TextWrapping="Wrap" Margin="0,0,0,20"/>
            </StackPanel>

            <!-- Центральная колонка - Услуги по категориям -->
            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                <TextBlock Text="Парикмахерские" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,0,0,5"/>

                <ListBox x:Name="hairServicesListBox" 
                        Background="White" Foreground="Black"
                        Height="120" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="ServiceName"
                        SelectionChanged="ServiceListBox_SelectionChanged"/>

                <TextBlock Text="Маникюр" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,10,0,5"/>

                <ListBox x:Name="manicureServicesListBox" 
                        Background="White" Foreground="Black"
                        Height="120" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="ServiceName"
                        SelectionChanged="ServiceListBox_SelectionChanged"/>

                <TextBlock Text="Педикюр" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,10,0,5"/>

                <ListBox x:Name="pedicureServicesListBox" 
                        Background="White" Foreground="Black"
                        Height="120" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="ServiceName"
                        SelectionChanged="ServiceListBox_SelectionChanged"/>
            </StackPanel>

            <!-- Правая колонка - Массаж и Анонимный клиент -->
            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <TextBlock Text="Массаж" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,0,0,5"/>

                <ListBox x:Name="massageServicesListBox" 
                        Background="White" Foreground="Black"
                        Height="120" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="ServiceName"
                        SelectionChanged="ServiceListBox_SelectionChanged"/>

                <TextBlock Text="Косметические" 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,10,0,5"/>

                <ListBox x:Name="cosmeticServicesListBox" 
                        Background="White" Foreground="Black"
                        Height="120" BorderBrush="#FF27AE60" BorderThickness="2"
                        DisplayMemberPath="ServiceName"
                        SelectionChanged="ServiceListBox_SelectionChanged"/>

                <TextBlock 
                         Foreground="White" FontWeight="Bold" 
                         FontSize="14" Margin="0,20,0,10" Text="Итоговый телефон клиента:&#xD;&#xA;"/>

                <TextBox x:Name="tempClientPhoneTextBox" 
                        FontSize="14" Padding="8" Margin="0,0,0,10"
                        Background="White" Foreground="Black" 
                        BorderThickness="1" BorderBrush="#FF27AE60"
                        ToolTip="Телефон случайного клиента"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Дата:" 
                             Foreground="White" FontWeight="Bold" 
                             FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <DatePicker x:Name="appointmentDatePicker" 
                               FontSize="14" Padding="8" Width="150"
                               Background="White" Foreground="Black" 
                               BorderThickness="1" BorderBrush="#FF27AE60"/>
                </StackPanel>

                <Button x:Name="createAppointmentButton" Content="💾 СОЗДАТЬ ЗАПИСЬ"
                        Click="CreateAppointmentButton_Click"
                        Background="#FF27AE60" Foreground="White"
                        Margin="0,20,0,0" Padding="15,10"
                        FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#FF145A32" CornerRadius="10" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="refreshButton" Content="🔄 ОБНОВИТЬ ДАННЫЕ"
                        Click="RefreshButton_Click"
                        Background="#FF3498DB" Foreground="White"
                        Margin="5" Padding="15,8"
                        FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="returnButton" Content="← ВЕРНУТЬСЯ"
                        Click="ReturnButton_Click"
                        Background="#FF95A5A6" Foreground="White"
                        Margin="5" Padding="15,8"
                        FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>